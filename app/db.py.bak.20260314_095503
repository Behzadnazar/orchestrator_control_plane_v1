def acquire_worker_lease(worker_id: str, task_id: str, ttl_seconds: int, details: dict[str, Any]) -> str:
    lease_id = new_id()
    now = utc_now()
    expires_at = (datetime.now(timezone.utc) + timedelta(seconds=ttl_seconds)).isoformat()
    with connect() as conn:
        existing = conn.execute(
            "SELECT lease_id, status FROM worker_leases WHERE task_id=?",
            (task_id,),
        ).fetchone()

        if existing:
            if existing["status"] == "active":
                raise sqlite3.IntegrityError(f"active lease already exists for task_id={task_id}")

            conn.execute(
                """
                UPDATE worker_leases
                SET lease_id=?, worker_id=?, status=?, acquired_at=?, expires_at=?, details_json=?
                WHERE task_id=?
                """,
                (
                    lease_id,
                    worker_id,
                    "active",
                    now,
                    expires_at,
                    json.dumps(details, ensure_ascii=False),
                    task_id,
                ),
            )
        else:
            conn.execute(
                """
                INSERT INTO worker_leases (lease_id, worker_id, task_id, status, acquired_at, expires_at, details_json)
                VALUES (?, ?, ?, ?, ?, ?, ?)
                """,
                (lease_id, worker_id, task_id, "active", now, expires_at, json.dumps(details, ensure_ascii=False)),
            )
    return lease_id

