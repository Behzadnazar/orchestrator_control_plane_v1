PRIORITY_ORDER = {
    "critical": 4,
    "high": 3,
    "normal": 2,
    "low": 1,
}

def enqueue_task(task_id: str, task_type: str, priority: str) -> str:
    queue_item_id = new_id()
    now = utc_now()
    with connect() as conn:
        existing = conn.execute(
            "SELECT queue_item_id FROM task_queue WHERE task_id=?",
            (task_id,),
        ).fetchone()
        if existing:
            return existing["queue_item_id"]

        conn.execute(
            """
            INSERT INTO task_queue (
                queue_item_id, task_id, task_type, priority, status,
                claimed_by_worker, claimed_at, created_at, updated_at
            )
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
            """,
            (queue_item_id, task_id, task_type, priority, "queued", None, None, now, now),
        )
    return queue_item_id

def claim_next_task(worker_id: str) -> dict[str, Any] | None:
    with connect() as conn:
        rows = conn.execute("""
            SELECT queue_item_id, task_id, task_type, priority, status, claimed_by_worker,
                   claimed_at, created_at, updated_at
            FROM task_queue
            WHERE status='queued'
            ORDER BY
                CASE priority
                    WHEN 'critical' THEN 4
                    WHEN 'high' THEN 3
                    WHEN 'normal' THEN 2
                    WHEN 'low' THEN 1
                    ELSE 0
                END DESC,
                created_at ASC
        """).fetchall()

        if not rows:
            return None

        row = rows[0]
        now = utc_now()
        conn.execute("""
            UPDATE task_queue
            SET status='claimed',
                claimed_by_worker=?,
                claimed_at=?,
                updated_at=?
            WHERE queue_item_id=?
            """, (worker_id, now, now, row["queue_item_id"]))

        task = conn.execute("""
            SELECT *
            FROM tasks
            WHERE task_id=?
            """, (row["task_id"],)).fetchone()

        if not task:
            return None

        return dict(task)

