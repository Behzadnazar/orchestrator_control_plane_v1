def recover_stale_claims(timeout_seconds: int) -> dict[str, Any]:
    now_dt = datetime.now(timezone.utc)
    now = now_dt.isoformat()

    with connect() as conn:
        rows = conn.execute(
            """
            SELECT queue_item_id, task_id, claimed_by_worker, claimed_at
            FROM task_queue
            WHERE status='claimed' AND claimed_at IS NOT NULL
            """
        ).fetchall()

        stale_task_ids: list[str] = []
        for r in rows:
            claimed_at = datetime.fromisoformat(r["claimed_at"])
            age = (now_dt - claimed_at).total_seconds()
            if age >= timeout_seconds:
                stale_task_ids.append(r["task_id"])

        requeued = 0
        for task_id in stale_task_ids:
            cur = conn.execute(
                """
                UPDATE task_queue
                SET status='queued',
                    claimed_by_worker=NULL,
                    claimed_at=NULL,
                    updated_at=?
                WHERE task_id=? AND status='claimed'
                """,
                (now, task_id),
            )
            requeued += cur.rowcount

        return {
            "stale_task_ids": stale_task_ids,
            "requeued": requeued,
        }

def claim_next_task_for_agent(worker_id: str, agent_type: str) -> dict[str, Any] | None:
    with connect() as conn:
        rows = conn.execute("""
            SELECT q.queue_item_id, q.task_id, q.task_type, q.priority, q.status,
                   q.claimed_by_worker, q.claimed_at, q.created_at, q.updated_at,
                   t.payload_json, t.status AS task_status
            FROM task_queue q
            JOIN tasks t ON t.task_id = q.task_id
            WHERE q.status='queued' AND t.status='Idle'
            ORDER BY
                CASE q.priority
                    WHEN 'critical' THEN 4
                    WHEN 'high' THEN 3
                    WHEN 'normal' THEN 2
                    WHEN 'low' THEN 1
                    ELSE 0
                END DESC,
                q.created_at ASC
        """).fetchall()

        selected_task = None
        for row in rows:
            task = conn.execute("SELECT * FROM tasks WHERE task_id=?", (row["task_id"],)).fetchone()
            if not task:
                continue
            try:
                routed = router.route_task(dict(task))
            except Exception:
                continue
            if routed["agent_type"] == agent_type:
                selected_task = dict(task)
                selected_queue_item_id = row["queue_item_id"]
                break

        if not selected_task:
            return None

        now = utc_now()
        cur = conn.execute(
            """
            UPDATE task_queue
            SET status='claimed',
                claimed_by_worker=?,
                claimed_at=?,
                updated_at=?
            WHERE queue_item_id=? AND status='queued'
            """,
            (worker_id, now, now, selected_queue_item_id),
        )
        if cur.rowcount != 1:
            return None

        return selected_task
