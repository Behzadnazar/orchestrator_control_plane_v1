def move_queue_item_to_dlq(task_id: str, reason: str) -> str:
    dlq_item_id = new_id()
    now = utc_now()
    with connect() as conn:
        row = conn.execute(
            """
            SELECT queue_item_id, task_id, task_type, priority
            FROM task_queue
            WHERE task_id=?
            """,
            (task_id,),
        ).fetchone()

        if not row:
            raise ValueError(f"queue item not found for task_id={task_id}")

        existing = conn.execute(
            "SELECT dlq_item_id FROM dead_letter_queue WHERE task_id=?",
            (task_id,),
        ).fetchone()
        if existing:
            return existing["dlq_item_id"]

        conn.execute(
            """
            INSERT INTO dead_letter_queue (
                dlq_item_id, task_id, task_type, priority, reason, source_queue_item_id, created_at
            )
            VALUES (?, ?, ?, ?, ?, ?, ?)
            """,
            (
                dlq_item_id,
                row["task_id"],
                row["task_type"],
                row["priority"],
                reason,
                row["queue_item_id"],
                now,
            ),
        )
        conn.execute(
            """
            UPDATE task_queue
            SET status='dead_letter',
                updated_at=?
            WHERE task_id=?
            """,
            (now, task_id),
        )
    return dlq_item_id

