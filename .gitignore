# Local databases / runtime state
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
data/
run/
runtime/
logs/

# Local artifacts that should not be versioned
artifacts/
tmp/
temp/

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Node / frontend caches if present
node_modules/
.next/
coverage/

# Secrets / keys
.env
.env.*
*.pem
*.key
*.p12
*.pfx

# Generated protobuf / binaries / compiled output
*.so
*.dylib
*.dll

